{
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist/"
  ],
  "license": "MIT",
  "name": "@korumite/kiwi",
  "packageManager": "pnpm@11.15.1",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/angrybacon/kiwi.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "lint": "pnpm run '/^lint:[^:]+$/'",
    "lint:code": "oxlint",
    "lint:format": "prettier --check --log-level warn lib/",
    "lint:prune": "knip",
    "lint:typings": "tsc",
    "test": "vitest run",
    "test:coverage": "pnpm run test --coverage",
    "test:watch": "pnpm run test --watch"
  },
  "dependencies": {
    "@types/mdast": "4.0.4",
    "mdast-util-directive": "3.1.0",
    "mdast-util-toc": "7.1.0",
    "reading-time": "1.5.0",
    "remark": "15.0.1",
    "remark-directive": "4.0.0",
    "remark-frontmatter": "5.0.0",
    "remark-parse": "11.0.0",
    "remark-stringify": "11.0.0",
    "unified": "11.0.5",
    "unist-util-remove": "4.0.0",
    "unist-util-visit": "5.1.0",
    "vfile-matter": "5.0.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@korumite/ts": "1.7.0",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "knip": "6.27.0",
    "memfs": "4.64.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "prettier": "3.9.5",
    "tsdown": "0.22.12",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
